---
import LogoBrand from "../ui/LogoBrand.astro";
---

<!-- ========== HEADER ========== -->
<header
  class="sticky top-0 inset-x-0 flex flex-wrap md:flex-nowrap z-50 w-full"
>
  <nav class="w-full md:w-11/12 mt-0 mx-auto px-4 my-5 backdrop-blur-md">
    <div class="mx-auto">
      <div class="flex justify-between">
        <div>
          <!-- Website Logo -->
          <a href="#" class="flex items-center py-4 px-2">
            <LogoBrand />
          </a>
        </div>
        <!-- Primary Navbar items -->
        <div class="hidden gap-5 md:flex items-center">
          <a href="/" id="link">Inicio</a>
          <a href="/servicios" id="link">Servicios</a>
          <a href="/nosotros" id="link">Nosotros</a>
          <a href="/blog" id="link">Blog</a>
        </div>

        <!-- Mobile menu button -->
        <div class="md:hidden flex items-center">
          <button
            class="flex border rounded-lg p-1 mobile-menu-button"
            aria-label="Open mobile menu"
          >
            <svg
              class="shrink-0 size-5"
              id="open-icon"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
              class="hidden shrink-0 size-5"
              id="close-icon"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              ><rect width="24" height="24" fill="none"></rect><path
                fill="#000"
                d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"
              ></path></svg
            >
          </button>
        </div>
      </div>
    </div>
    <!-- Mobile menu -->
    <div class="mobile-menu md:hidden flex flex-col justify-start gap-5">
      <a href="/" id="link">Inicio</a>
      <a href="/servicios" id="link">Servicios</a>
      <a href="/nosotros" id="link">Nosotros</a>
      <a href="/blog" id="link">Blog</a>
    </div>
  </nav>
  <!-- ========== END HEADER ========== -->
</header>

<style>
  .mobile-menu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
  }
  .mobile-menu.open {
    max-height: 1000px;
    transition: max-height 0.5s ease-in;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const activeLinks = document.querySelectorAll("#link");

    const currentPath = window.location.pathname;

    activeLinks.forEach((link) => {
      if (link.getAttribute("href") === currentPath) {
        link.classList.add("text-colorKidsorangeWeb");
      } else {
        link.classList.remove("text-colorKidsorangeWeb");
      }
    });

    const btn = document.querySelector(
      "button.mobile-menu-button",
    ) as HTMLButtonElement;
    const menu = document.querySelector(".mobile-menu") as HTMLDivElement;
    const openIcon = document.querySelector("#open-icon") as HTMLElement;
    const closeIcon = document.querySelector("#close-icon") as HTMLElement;

    btn.addEventListener("click", () => {
      menu.classList.toggle("open");
      openIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  });
</script>
