---
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="es.COL">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-white w-full min-h-screen mx-auto p-10">
    <a
      class="transition hover:text-colorKidsorangeWeb duration-300 hover:underline hover:underline-offset-4"
      href="/blog"
    >
      Regresar al blog
    </a>

    <main class="w-11/12 px-4 py-10 sm:px-6 lg:px-8 lg:py-14 mx-auto">
      <slot />
    </main>
  </body>
</html>
